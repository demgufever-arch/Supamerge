# Server
PORT=3000
NODE_ENV=development

# API Key Secret (used to sign/verify API keys)
API_KEY_SECRET=your-super-secret-key-change-this

# Database Configuration (for storing API keys and database configs)
# Using SQLite for simplicity, or use any database
MASTER_DB_TYPE=sqlite
MASTER_DB_PATH=./database.sqlite

# Optional: Use PostgreSQL for master database instead
# MASTER_DB_TYPE=postgresql
# MASTER_DB_HOST=localhost
# MASTER_DB_PORT=5432
# MASTER_DB_NAME=gateway_db
# MASTER_DB_USER=postgres
# MASTER_DB_PASSWORD=postgres

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
